          "output_type": "stream",
          "name": "stdout",
          "text": [
            "digite o primeiro numero: 1\n",
            "digite o segundo numero: 1\n",
            "1.0 + 1.0 = 2.0\n",
            "digite o primeiro numero: 2\n",
            "digite o segundo numero: 2\n",
            "2.0 - 2.0 = 0.0\n",
            "digite o primeiro numero: 3\n",
            "digite o segundo numero: 3\n",
            "3.0 / 3.0 = 1.0\n",
            "digite o primeiro numero: 3\n",
            "digite o segundo numero: 3\n",
            "3.0 x 3.0 = 9.0\n"
          ]
        }
      ],
      "source": [
        "def soma(n1, n2):\n",
        "  result = n1 + n2\n",
        "  return result\n",
        "n1 = float(input(\"digite o primeiro numero: \"))\n",
        "n2 = float(input(\"digite o segundo numero: \"))\n",
        "somaresult = soma(n1, n2)\n",
        "print(f\"{n1} + {n2} = {somaresult}\")\n",
        "\n",
        "def sub(n1, n2):\n",
        "  result = n1 - n2\n",
        "  return result\n",
        "n1 = float(input(\"digite o primeiro numero: \"))\n",
        "n2 = float(input(\"digite o segundo numero: \"))\n",
        "subresult = sub(n1, n2)\n",
        "print(f\"{n1} - {n2} = {subresult}\")\n",
        "\n",
        "def div(n1, n2):\n",
        "  result = n1 / n2\n",
        "  return result\n",
        "n1 = float(input(\"digite o primeiro numero: \"))\n",
        "n2 = float(input(\"digite o segundo numero: \"))\n",
        "divresult = div(n1, n2)\n",
        "print(f\"{n1} / {n2} = {divresult}\")\n",
        "\n",
        "def mult(n1, n2):\n",
        "  result = n1 * n2\n",
        "  return result\n",
        "n1 = float(input(\"digite o primeiro numero: \"))\n",
        "n2 = float(input(\"digite o segundo numero: \"))\n",
        "multresult = mult(n1, n2)\n",
        "print(f\"{n1} x {n2} = {multresult}\")"
      ]
    }
  ]
